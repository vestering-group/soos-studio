---
import '../styles/global.css';
import '@fontsource/instrument-serif';
import '@fontsource/dm-mono';
import { site } from '../content/site';
import BottomBar from '../components/BottomBar.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.naam} — foto’s & reels voor lokale bedrijven</title>
    <meta name="description" content={site.beschrijving} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="sitemap" href={`${base}/sitemap-index.xml`} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content={site.naam} />
    <meta property="og:title" content={`${site.naam} — foto’s & reels voor lokale bedrijven`} />
    <meta property="og:description" content={site.beschrijving} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
  </head>
  <body class="bg-bone-paper text-ink pb-24">
    <a
      href="#contact"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 mono-label bg-pure-white px-4 py-2 border border-ink rounded-sm"
    >
      Direct naar contact
    </a>

    <slot />

    <BottomBar />

    <script>
      // Reveal op scroll met stagger: elementen die tegelijk in beeld komen
      // verschijnen kort na elkaar — geen libraries.
      const observer = new IntersectionObserver(
        (entries) => {
          const zichtbaar = entries.filter((e) => e.isIntersecting);
          zichtbaar.forEach((entry, i) => {
            const el = entry.target as HTMLElement;
            el.style.transitionDelay = `${i * 90}ms`;
            el.classList.add('is-visible');
            observer.unobserve(el);
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal, .reveal-img').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
