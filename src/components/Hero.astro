---
import { hero } from '../content/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header id="top" class="relative min-h-[92vh] flex items-center justify-center overflow-hidden px-6">
  <!-- Scattered editorial placeholders rond de kop (verborgen op mobiel) -->
  <img
    src={`${base}/portfolio/reel-placeholder-1.svg`}
    alt=""
    aria-hidden="true"
    class="hidden md:block absolute w-28 lg:w-36 rounded-sm top-[12%] left-[8%] -rotate-3"
  />
  <img
    src={`${base}/portfolio/foto-placeholder-1.svg`}
    alt=""
    aria-hidden="true"
    class="hidden md:block absolute w-32 lg:w-40 rounded-sm top-[18%] right-[7%] rotate-2"
  />
  <img
    src={`${base}/portfolio/reel-placeholder-2.svg`}
    alt=""
    aria-hidden="true"
    class="hidden lg:block absolute w-24 rounded-sm bottom-[20%] left-[14%] rotate-1"
  />
  <img
    src={`${base}/portfolio/foto-placeholder-2.svg`}
    alt=""
    aria-hidden="true"
    class="hidden lg:block absolute w-28 rounded-sm bottom-[14%] right-[12%] -rotate-2"
  />

  <div class="max-w-4xl text-center">
    <p class="mono-label text-ash mb-8">Contentstudio voor lokale bedrijven</p>

    <!-- Signatuurpatroon: foto inline in de kop, op de tekstbaseline -->
    <h1 class="text-heading-lg">
      {hero.kopVoor}
      <img
        src={`${base}/isabella-portret.svg`}
        alt={hero.kopFotoAlt}
        class="inline-block h-[0.95em] w-auto rounded-sm align-baseline mx-1"
      />
      {hero.kopNa}
    </h1>

    <p class="text-body-sm text-ink max-w-2xl mx-auto mt-8">{hero.subkop}</p>

    <div class="flex items-center justify-center gap-3 mt-10 flex-wrap">
      <a href="#contact" class="btn-lime">{hero.ctaPrimair}</a>
      <a href="#pakketten" class="btn-ghost">{hero.ctaSecundair}</a>
    </div>
  </div>

  <!-- Scroll-indicator rechtsonder -->
  <a
    href="#voor-wie"
    class="mono-label absolute bottom-6 right-6 hidden sm:flex items-center gap-2"
    aria-label="Scroll naar beneden"
  >
    Scroll
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="2" />
    </svg>
  </a>
</header>
