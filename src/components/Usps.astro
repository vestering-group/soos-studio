---
import { usps } from '../content/site';
---

<section class="px-6 py-24 md:py-32 bg-pure-white border-y border-ink/10">
  <div class="max-w-5xl mx-auto">
    <p class="mono-label text-ash mb-12 reveal">{usps.label}</p>
    <div class="grid sm:grid-cols-2 gap-x-12 gap-y-14">
      {
        usps.punten.map((punt) => (
          <div class="reveal">
            <h3 class="text-body mb-3">{punt.titel}</h3>
            <p class="text-body-sm text-ink/80">{punt.tekst}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
