---
import { portfolio } from '../content/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="werk" class="px-6 py-24 md:py-32">
  <div class="max-w-6xl mx-auto">
    <p class="mono-label text-ash mb-6 reveal">{portfolio.label}</p>
    <h2 class="text-heading mb-4 reveal">{portfolio.kop}</h2>
    <p class="text-body-sm text-ink/80 mb-14 reveal">{portfolio.tekst}</p>

    <!-- Beeldgrid: reels in 9:16, foto's in 4:5 — rauw op het canvas, geen kaders -->
    <div class="columns-2 md:columns-3 gap-4 [&>img]:mb-4">
      {
        portfolio.items.map((item) => (
          <img
            src={`${base}/${item.src}`}
            alt={item.alt}
            loading="lazy"
            class:list={['w-full rounded-sm reveal', item.type === 'reel' ? 'aspect-[9/16]' : 'aspect-[4/5]', 'object-cover']}
          />
        ))
      }
    </div>
  </div>
</section>
