---
import { hero } from '../content/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Zwevende editorial foto's rond de kop: positie, rotatie, entrance-delay
// en parallax-snelheid per foto (wrapper krijgt parallax, img de entrance).
const fotos = [
  { src: 'portfolio/reel-placeholder-1.svg', pos: 'top-[12%] left-[8%] w-28 lg:w-36 hidden md:block', rot: '-3deg', d: '0.9s', parallax: 0.08 },
  { src: 'portfolio/foto-placeholder-1.svg', pos: 'top-[18%] right-[7%] w-32 lg:w-40 hidden md:block', rot: '2deg', d: '1.05s', parallax: 0.05 },
  { src: 'portfolio/reel-placeholder-2.svg', pos: 'bottom-[20%] left-[14%] w-24 hidden lg:block', rot: '1deg', d: '1.2s', parallax: 0.12 },
  { src: 'portfolio/foto-placeholder-2.svg', pos: 'bottom-[14%] right-[12%] w-28 hidden lg:block', rot: '-2deg', d: '1.35s', parallax: 0.07 },
];
---

<header id="top" class="relative min-h-[92vh] flex items-center justify-center overflow-hidden px-6">
  {
    fotos.map((foto) => (
      <div class:list={['absolute', foto.pos]} data-parallax={foto.parallax}>
        <img
          src={`${base}/${foto.src}`}
          alt=""
          aria-hidden="true"
          class="hero-photo-img w-full rounded-sm"
          style={`--rot: ${foto.rot}; --d: ${foto.d}`}
        />
      </div>
    ))
  }

  <div class="max-w-4xl text-center">
    <p class="mono-label text-ash mb-8 intro" style="--d: 0.1s">Contentstudio voor lokale bedrijven</p>

    <!-- Signatuurpatroon: foto inline in de kop, op de tekstbaseline -->
    <h1 class="text-heading-lg intro" style="--d: 0.25s">
      {hero.kopVoor}
      <img
        src={`${base}/isabella-portret.svg`}
        alt={hero.kopFotoAlt}
        class="inline-photo inline-block h-[0.95em] w-auto rounded-sm align-baseline mx-1"
        style="--d: 0.8s"
      />
      {hero.kopNa}
    </h1>

    <p class="text-body-sm text-ink max-w-2xl mx-auto mt-8 intro" style="--d: 0.45s">{hero.subkop}</p>

    <div class="flex items-center justify-center gap-3 mt-10 flex-wrap intro" style="--d: 0.6s">
      <a href="#contact" class="btn-accent">{hero.ctaPrimair}</a>
      <a href="#pakketten" class="btn-ghost">{hero.ctaSecundair}</a>
    </div>
  </div>

  <!-- Scroll-indicator rechtsonder -->
  <a
    href="#voor-wie"
    class="mono-label absolute bottom-6 right-6 hidden sm:flex items-center gap-2 intro"
    style="--d: 1.5s"
    aria-label="Scroll naar beneden"
  >
    Scroll
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="2" />
    </svg>
  </a>
</header>
